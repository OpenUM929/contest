{
  "schema_version": "2026-04-v1",
  "description": "Vector DB 검색 패턴 정의 - 쿼리 확장 및 라벨 트리거",
  "last_updated": "2026-04-29",
  "conditional_promises": {
    "description": "조건부 약속 패턴 - 보상/승진을 미끼로 한 manipulative 행동",
    "regex_patterns": [
      "하면.*해주",
      "하면.*시켜",
      "좋으면.*승진",
      "달성하면.*보상",
      "지키지.*못",
      "성과.*승진"
    ],
    "triggered_labels": ["N02-02", "N02-01", "N02-03"],
    "vector_expansion": "N02-02 manipulative 지킬수없는약속 거짓보상 조건부보상 empty promise",
    "context": "normal",
    "example_texts": [
      "이번 quarter 성과 좋으면 즉시 승진시켜드립니다",
      "목표 달성하면 보상하겠습니다",
      "성과 있으면 즉시 승진해주겠다"
    ]
  },
  "adversative": {
    "description": "역접/부정 패턴 - 말과 행동의 불일치 또는 부정적 전환",
    "explicit": {
      "patterns": ["하지만", "그러나", "그런데"],
      "type": "explicit_adversative",
      "triggered_action": "force_llm_call",
      "description": "명시적 역접 - LLM 강제 호출"
    },
    "implicit_negative": {
      "patterns": [
        "실제로는",
        "사실과.*다르",
        "실제.*는.*않",
        "지키지.*못",
        "않았",
        "못했",
        "실제.*인데",
        "실제.*매출",
        "실제.*숫자"
      ],
      "type": "implicit_negative",
      "triggered_labels": ["N30-01", "N28-01", "N34-01"],
      "vector_expansion": "N30-01 말행불일치 N28-01 정보조작 거짓말 기만 숫자조작 실제와다름",
      "description": "암시적 부정 - 실제와 다른 상황 감지"
    }
  },
  "negative_patterns": {
    "termination_threats": {
      "patterns": ["해고", "그만둬", "쫓아내"],
      "triggered_labels": ["N02-01"],
      "context": "normal",
      "description": "해고 위협 - 공포 기반 동기 유도"
    },
    "reward_exaggeration": {
      "patterns": ["승진시켜", "보상.*주겠", "약속.*지키"],
      "triggered_labels": ["N02-02", "N30-01"],
      "context": "normal",
      "description": "보상 과장 약속 - 지킬 수 없는 약속"
    },
    "words_actions_mismatch": {
      "patterns": ["말과.*행동.*불일치", "실제로는", "사실과.*다르"],
      "triggered_labels": ["N30-01", "N28-01"],
      "critical": true,
      "description": "말행불일치 - integrity violation"
    },
    "data_manipulation": {
      "patterns": ["숫자.*조작", "보고서.*다르", "실적.*부풀"],
      "triggered_labels": ["N34-01", "N28-01"],
      "critical": true,
      "description": "데이터 조작 - 의도적 정보 왜곡"
    }
  },
  "crisis_patterns": {
    "description": "위기 상황 패턴",
    "keywords": ["문제", "발생", "긴급", "위기", "빠르게", "결론", "즉시"],
    "special_patterns": {
      "문제가 발생": {
        "expansion": "문제 발생 위기 상황 긴급 위기",
        "labels": ["M19-01", "M20-01", "M10-01"]
      },
      "빠르게 결론": {
        "expansion": "빠르게 결론 신속 의사결정 즉시 결정",
        "labels": ["M19-01", "M10-01"]
      },
      "내 안내대로": {
        "expansion": "안내 지시 명확한 역할",
        "labels": ["M19-01", "M17-01"]
      }
    },
    "context_weight_adjustments": {
      "N08": 1.3,
      "N18": 1.3,
      "N28": 1.3,
      "N33": 1.3,
      "M20": 1.2
    }
  },
  "innovation_patterns": {
    "description": "혁신/창의 패턴",
    "keywords": ["새로운", "혁신", "도전", "창의"],
    "context_expansion": "혁신 창의 새로운 변화",
    "context_weight_adjustments": {
      "N01": 1.3,
      "N03": 1.3,
      "N05": 1.3,
      "N23": 1.3,
      "N26": 1.3,
      "M03": 1.3,
      "M05": 1.2,
      "M23": 1.3
    },
    "positive_labels": ["M03-01", "M03-03", "M05-02", "M23-01", "M22-01"]
  },
  "test_case_mapping": {
    "T105-A": {
      "text": "이번 quarter 성과 좋으면 즉시 승진시켜드립니다. 하지만 실제로는 그런 일 없습니다. 안 하면 해고하겠습니다.",
      "matched_patterns": ["conditional_promises", "explicit_adversative", "termination_threats"],
      "expected_labels": ["N02-02", "N02-01", "N02-03"]
    },
    "T105-B": {
      "text": "이번엔 꼭 승진시켜줄게. 그런데 실제로는 보상을 주지 않아. 이렇게밖에 안 되면 그만둬.",
      "matched_patterns": ["conditional_promises", "explicit_adversative", "reward_exaggeration"],
      "expected_labels": ["N02-02", "N01-02", "N06-02"]
    },
    "T103-A": {
      "text": "실제 매출은 10%인데 보고서엔 30% 성장이라고 적겠습니다. 중요한 숫자들은 사내에서만 알고 있지요.",
      "matched_patterns": ["implicit_negative", "data_manipulation"],
      "expected_labels": ["N30-01", "N28-01", "N34-01"]
    },
    "T04-B": {
      "text": "문제가 발생했다. 지금 상황을 분석하고 있다. 빠르게 결론을 내릴 것이다. 모두 내 안내대로 행동해달라.",
      "matched_patterns": ["crisis_patterns"],
      "expected_labels": ["M19-01", "M10-01", "M20-01"]
    }
  },
  "llm_call_rules": {
    "force_llm_conditions": [
      "explicit_adversative detected",
      "implicit_negative detected",
      "confidence between 0.60 and 0.84"
    ],
    "skip_llm_conditions": [
      "confidence >= 0.70",
      "no adversative particles"
    ]
  }
}
