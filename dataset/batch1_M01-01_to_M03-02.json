[
  {"text": "우리 팀의 올해 목표는 고객 만족도 90점 이상 달성입니다.", "label_id": "M01-01", "label_name": "명확한 비전 제시", "label_type": "positive", "data_type": "clean"},
  {"text": "팀장이 전체 회의에서 2026년까지 시장 점유율 30%를 달성하겠다고 선언했다.", "label_id": "M01-01", "label_name": "명확한 비전 제시", "label_type": "positive", "data_type": "clean"},
  {"text": "이 프로젝트의 최종 목표는 6개월 내 사용자 10만 명 확보입니다.", "label_id": "M01-01", "label_name": "명확한 비전 제시", "label_type": "positive", "data_type": "clean"},
  {"text": "리더가 구체적인 수치와 기한을 포함한 팀 목표를 칠판에 적으며 설명했다.", "label_id": "M01-01", "label_name": "명확한 비전 제시", "label_type": "positive", "data_type": "clean"},
  {"text": "우리가 나아가야 할 방향은 B2B 시장 집중 공략입니다. 이를 위해 올해 파트너사 20곳을 확보하겠습니다.", "label_id": "M01-01", "label_name": "명확한 비전 제시", "label_type": "positive", "data_type": "clean"},
  {"text": "팀장은 분기마다 팀 목표를 문서로 정리해 전원과 공유했다.", "label_id": "M01-01", "label_name": "명확한 비전 제시", "label_type": "positive", "data_type": "clean"},
  {"text": "이번 반기 목표를 명확히 하는 것이 좋겠습니다. 매출 15% 성장을 기준으로 잡겠습니다.", "label_id": "M01-01", "label_name": "명확한 비전 제시", "label_type": "positive", "data_type": "clean"},
  {"text": "우리 팀의 미션은 고객이 제품을 쓰는 첫날부터 가치를 느끼게 하는 것입니다.", "label_id": "M01-01", "label_name": "명확한 비전 제시", "label_type": "positive", "data_type": "clean"},
  {"text": "회의에서 팀장이 목표 수치를 화면에 띄우고 각 지표의 의미를 설명하는 분위기가 형성됐다.", "label_id": "M01-01", "label_name": "명확한 비전 제시", "label_type": "positive", "data_type": "clean"},
  {"text": "이 방향으로 가는 것이 맞다고 생각합니다. 3분기 말까지 베타 출시를 목표로 하면 어떨까요.", "label_id": "M01-01", "label_name": "명확한 비전 제시", "label_type": "positive", "data_type": "clean"},
  {"text": "열심히 하면 좋은 결과가 있을 거예요. 모두 파이팅입니다.", "label_id": "M01-01", "label_name": "명확한 비전 제시", "label_type": "positive", "data_type": "hard_negative", "is_negative_of": "M01-01"},
  {"text": "방향은 나중에 정하고 일단 시작합시다.", "label_id": "M01-01", "label_name": "명확한 비전 제시", "label_type": "positive", "data_type": "hard_negative", "is_negative_of": "M01-01"},
  {"text": "팀장이 큰 그림을 그리자고 했지만 구체적인 수치나 기한을 제시하지 않았다.", "label_id": "M01-01", "label_name": "명확한 비전 제시", "label_type": "positive", "data_type": "hard_negative", "is_negative_of": "M01-01"},
  {"text": "우리 팀이 잘 해낼 것이라고 믿습니다. 최선을 다해주세요.", "label_id": "M01-01", "label_name": "명확한 비전 제시", "label_type": "positive", "data_type": "hard_negative", "is_negative_of": "M01-01"},
  {"text": "목표요? 그냥 지금보다 더 잘하면 되죠.", "label_id": "M01-01", "label_name": "명확한 비전 제시", "label_type": "positive", "data_type": "hard_negative", "is_negative_of": "M01-01"},

  {"text": "향후 5년간 우리 팀은 플랫폼 기업으로 전환하는 방향으로 성장할 것입니다.", "label_id": "M01-02", "label_name": "장기 방향 설정", "label_type": "positive", "data_type": "clean"},
  {"text": "팀장이 2028년까지의 로드맵을 슬라이드로 정리해 전체에 공유했다.", "label_id": "M01-02", "label_name": "장기 방향 설정", "label_type": "positive", "data_type": "clean"},
  {"text": "장기적으로 보면 AI 기반 서비스로 피벗하는 것이 맞습니다. 3년 계획을 함께 세워봅시다.", "label_id": "M01-02", "label_name": "장기 방향 설정", "label_type": "positive", "data_type": "clean"},
  {"text": "2030년까지 동남아 시장 3개국 진출을 전략 방향으로 잡겠습니다.", "label_id": "M01-02", "label_name": "장기 방향 설정", "label_type": "positive", "data_type": "clean"},
  {"text": "리더는 5년 로드맵을 기반으로 올해 어떤 역량을 쌓아야 하는지 팀원에게 설명했다.", "label_id": "M01-02", "label_name": "장기 방향 설정", "label_type": "positive", "data_type": "clean"},
  {"text": "단기 성과도 중요하지만, 우리가 3년 후 어디에 있어야 하는지부터 정리해야 합니다.", "label_id": "M01-02", "label_name": "장기 방향 설정", "label_type": "positive", "data_type": "clean"},
  {"text": "중장기 전략 방향을 공유드리겠습니다. 올해부터 2027년까지 단계별 계획입니다.", "label_id": "M01-02", "label_name": "장기 방향 설정", "label_type": "positive", "data_type": "clean"},
  {"text": "팀의 5년 방향성을 설정하는 워크숍이 진행됐고, 팀장이 직접 퍼실리테이터를 맡았다.", "label_id": "M01-02", "label_name": "장기 방향 설정", "label_type": "positive", "data_type": "clean"},
  {"text": "지금 당장의 숫자보다 5년 뒤 우리 팀이 무엇을 하고 있을지를 먼저 그려봅시다.", "label_id": "M01-02", "label_name": "장기 방향 설정", "label_type": "positive", "data_type": "clean"},
  {"text": "장기적 관점에서 기술 부채를 해소하는 방향으로 가는 것이 좋겠습니다.", "label_id": "M01-02", "label_name": "장기 방향 설정", "label_type": "positive", "data_type": "clean"},
  {"text": "이번 달 목표는 보고서 3건 제출입니다.", "label_id": "M01-02", "label_name": "장기 방향 설정", "label_type": "positive", "data_type": "hard_negative", "is_negative_of": "M01-02"},
  {"text": "오늘 회의 안건은 이번 주 업무 배분입니다.", "label_id": "M01-02", "label_name": "장기 방향 설정", "label_type": "positive", "data_type": "hard_negative", "is_negative_of": "M01-02"},
  {"text": "분기 목표를 달성하는 데 집중합시다.", "label_id": "M01-02", "label_name": "장기 방향 설정", "label_type": "positive", "data_type": "hard_negative", "is_negative_of": "M01-02"},
  {"text": "팀장이 이번 스프린트 태스크를 배분하며 각자 역할을 설명했다.", "label_id": "M01-02", "label_name": "장기 방향 설정", "label_type": "positive", "data_type": "hard_negative", "is_negative_of": "M01-02"},
  {"text": "내일 마감이니 오늘 안에 끝내주세요.", "label_id": "M01-02", "label_name": "장기 방향 설정", "label_type": "positive", "data_type": "hard_negative", "is_negative_of": "M01-02"},

  {"text": "개인 OKR을 팀 목표와 연결해봅시다. 각자 어느 부분에 기여하는지 확인하겠습니다.", "label_id": "M01-03", "label_name": "목표 정렬", "label_type": "positive", "data_type": "clean"},
  {"text": "팀장이 각 팀원의 업무가 전체 목표에 어떻게 연결되는지 1:1로 설명했다.", "label_id": "M01-03", "label_name": "목표 정렬", "label_type": "positive", "data_type": "clean"},
  {"text": "여러분의 개인 성장 방향이 팀 목표와 일치하도록 조정하겠습니다.", "label_id": "M01-03", "label_name": "목표 정렬", "label_type": "positive", "data_type": "clean"},
  {"text": "목표 정렬 세션을 통해 각 팀원이 자신의 역할이 전사 목표에 미치는 영향을 이해하게 됐다.", "label_id": "M01-03", "label_name": "목표 정렬", "label_type": "positive", "data_type": "clean"},
  {"text": "팀 목표와 본인 성장 목표가 겹치는 부분을 찾아봅시다. 그 교집합이 우선순위입니다.", "label_id": "M01-03", "label_name": "목표 정렬", "label_type": "positive", "data_type": "clean"},
  {"text": "이번 분기 팀 KPI와 각자의 개인 목표를 함께 놓고 방향을 맞추는 시간을 가졌다.", "label_id": "M01-03", "label_name": "목표 정렬", "label_type": "positive", "data_type": "clean"},
  {"text": "여러분이 하는 일 하나하나가 팀 목표에 어떻게 기여하는지 설명드리겠습니다.", "label_id": "M01-03", "label_name": "목표 정렬", "label_type": "positive", "data_type": "clean"},
  {"text": "개인 목표와 팀 목표가 어긋나 있다면 지금 조정하는 것이 좋겠습니다.", "label_id": "M01-03", "label_name": "목표 정렬", "label_type": "positive", "data_type": "clean"},
  {"text": "팀장이 신규 입사자에게 팀 미션과 본인 역할의 연관성을 설명하며 온보딩을 진행했다.", "label_id": "M01-03", "label_name": "목표 정렬", "label_type": "positive", "data_type": "clean"},
  {"text": "각자 하고 싶은 일을 하되, 팀 방향과 크게 어긋나지 않도록 조율해봅시다.", "label_id": "M01-03", "label_name": "목표 정렬", "label_type": "positive", "data_type": "clean"},
  {"text": "올해 팀 목표는 매출 20억입니다. 열심히 하세요.", "label_id": "M01-03", "label_name": "목표 정렬", "label_type": "positive", "data_type": "hard_negative", "is_negative_of": "M01-03"},
  {"text": "팀 목표는 팀장이 정하는 겁니다. 따라오시면 됩니다.", "label_id": "M01-03", "label_name": "목표 정렬", "label_type": "positive", "data_type": "hard_negative", "is_negative_of": "M01-03"},
  {"text": "본인 업무에만 집중하세요. 큰 그림은 제가 봅니다.", "label_id": "M01-03", "label_name": "목표 정렬", "label_type": "positive", "data_type": "hard_negative", "is_negative_of": "M01-03"},
  {"text": "목표는 이미 정해졌으니 실행만 하면 됩니다.", "label_id": "M01-03", "label_name": "목표 정렬", "label_type": "positive", "data_type": "hard_negative", "is_negative_of": "M01-03"},
  {"text": "팀장이 전체 목표를 공지했지만 개인별 연결고리는 설명하지 않았다.", "label_id": "M01-03", "label_name": "목표 정렬", "label_type": "positive", "data_type": "hard_negative", "is_negative_of": "M01-03"},

  {"text": "오늘 전체 회의에서 우리 팀 비전을 다시 한번 공유하겠습니다.", "label_id": "M01-04", "label_name": "비전 공유", "label_type": "positive", "data_type": "clean"},
  {"text": "팀장이 신규 입사자에게 팀 미션과 핵심 가치를 직접 설명하는 온보딩을 진행했다.", "label_id": "M01-04", "label_name": "비전 공유", "label_type": "positive", "data_type": "clean"},
  {"text": "월간 뉴스레터에 팀 비전과 이번 달 진행 상황을 담아 전원에게 발송했다.", "label_id": "M01-04", "label_name": "비전 공유", "label_type": "positive", "data_type": "clean"},
  {"text": "매 분기 시작마다 팀 전체가 모여 우리가 왜 이 일을 하는지를 다시 되새기는 자리를 가졌다.", "label_id": "M01-04", "label_name": "비전 공유", "label_type": "positive", "data_type": "clean"},
  {"text": "팀 슬랙 채널에 매주 팀 미션을 상기시키는 메시지를 꾸준히 올리고 있습니다.", "label_id": "M01-04", "label_name": "비전 공유", "label_type": "positive", "data_type": "clean"},
  {"text": "우리 팀이 존재하는 이유를 모두가 알아야 합니다. 오늘 그 이야기를 나눠봅시다.", "label_id": "M01-04", "label_name": "비전 공유", "label_type": "positive", "data_type": "clean"},
  {"text": "비전 공유 세션이 끝난 후 팀원들이 자신의 업무와 팀 방향의 연결고리를 더 명확히 이해하는 분위기가 형성됐다.", "label_id": "M01-04", "label_name": "비전 공유", "label_type": "positive", "data_type": "clean"},
  {"text": "팀 위키에 미션과 비전을 정리해두고 신규 입사자가 첫날 반드시 읽도록 안내했습니다.", "label_id": "M01-04", "label_name": "비전 공유", "label_type": "positive", "data_type": "clean"},
  {"text": "분기마다 비전 점검 회의를 열어 방향이 흔들리지 않는지 확인하는 것이 좋겠습니다.", "label_id": "M01-04", "label_name": "비전 공유", "label_type": "positive", "data_type": "clean"},
  {"text": "팀장이 타운홀 미팅에서 팀의 방향성과 올해 집중할 가치를 다시 강조했다.", "label_id": "M01-04", "label_name": "비전 공유", "label_type": "positive", "data_type": "clean"},
  {"text": "비전은 작년에 한 번 공유했으니 됐습니다. 이제 실행하면 됩니다.", "label_id": "M01-04", "label_name": "비전 공유", "label_type": "positive", "data_type": "hard_negative", "is_negative_of": "M01-04"},
  {"text": "팀 미션 문서는 있는데 아무도 읽지 않아서 의미가 없어졌다.", "label_id": "M01-04", "label_name": "비전 공유", "label_type": "positive", "data_type": "hard_negative", "is_negative_of": "M01-04"},
  {"text": "비전은 경영진이 정하는 거고, 우리는 그냥 주어진 일을 하면 됩니다.", "label_id": "M01-04", "label_name": "비전 공유", "label_type": "positive", "data_type": "hard_negative", "is_negative_of": "M01-04"},
  {"text": "팀 방향을 공유한다고 했지만 일부 팀원에게만 선택적으로 전달됐다.", "label_id": "M01-04", "label_name": "비전 공유", "label_type": "positive", "data_type": "hard_negative", "is_negative_of": "M01-04"},
  {"text": "비전 발표가 형식적으로 끝나고 팀원들은 실제 업무와의 연관성을 느끼지 못했다.", "label_id": "M01-04", "label_name": "비전 공유", "label_type": "positive", "data_type": "hard_negative", "is_negative_of": "M01-04"},

  {"text": "이 일이 왜 중요한지 먼저 말씀드리겠습니다. 우리 고객 삶에 직접 영향을 미치는 작업입니다.", "label_id": "M02-01", "label_name": "내재적 동기 자극", "label_type": "positive", "data_type": "clean"},
  {"text": "방법은 스스로 정해보세요. 어떻게 접근하든 지원하겠습니다.", "label_id": "M02-01", "label_name": "내재적 동기 자극", "label_type": "positive", "data_type": "clean"},
  {"text": "팀장이 보상보다는 이 프로젝트가 사회에 미치는 의미를 강조하며 팀원들의 자발적 참여를 이끌었다.", "label_id": "M02-01", "label_name": "내재적 동기 자극", "label_type": "positive", "data_type": "clean"},
  {"text": "여러분이 하고 싶은 방식으로 진행해보세요. 틀을 정해드리는 것보다 자율성이 더 중요합니다.", "label_id": "M02-01", "label_name": "내재적 동기 자극", "label_type": "positive", "data_type": "clean"},
  {"text": "이 기능을 만들면 수천 명의 불편이 해결됩니다. 그 의미를 생각하며 작업해주세요.", "label_id": "M02-01", "label_name": "내재적 동기 자극", "label_type": "positive", "data_type": "clean"},
  {"text": "팀원 스스로 의미 있다고 느끼는 업무를 맡겼더니 야근도 자발적으로 하는 분위기가 만들어졌다.", "label_id": "M02-01", "label_name": "내재적 동기 자극", "label_type": "positive", "data_type": "clean"},
  {"text": "보너스보다 이 일 자체가 의미 있다는 걸 느꼈으면 좋겠습니다.", "label_id": "M02-01", "label_name": "내재적 동기 자극", "label_type": "positive", "data_type": "clean"},
  {"text": "각자가 가장 잘할 수 있고 즐길 수 있는 영역을 맡아주세요.", "label_id": "M02-01", "label_name": "내재적 동기 자극", "label_type": "positive", "data_type": "clean"},
  {"text": "이 프로젝트를 통해 여러분이 성장하는 게 저에게는 가장 중요한 성과입니다.", "label_id": "M02-01", "label_name": "내재적 동기 자극", "label_type": "positive", "data_type": "clean"},
  {"text": "어떤 방법으로 해결할지는 여러분이 결정하세요. 프로세스는 자율에 맡깁니다.", "label_id": "M02-01", "label_name": "내재적 동기 자극", "label_type": "positive", "data_type": "clean"},
  {"text": "이번 달 실적 달성하면 인센티브 드리겠습니다.", "label_id": "M02-01", "label_name": "내재적 동기 자극", "label_type": "positive", "data_type": "hard_negative", "is_negative_of": "M02-01"},
  {"text": "목표 못 채우면 다음 달 평가에 반영됩니다.", "label_id": "M02-01", "label_name": "내재적 동기 자극", "label_type": "positive", "data_type": "hard_negative", "is_negative_of": "M02-01"},
  {"text": "잘하면 승진 기회가 생길 수 있어요. 그걸 목표로 하세요.", "label_id": "M02-01", "label_name": "내재적 동기 자극", "label_type": "positive", "data_type": "hard_negative", "is_negative_of": "M02-01"},
  {"text": "팀장이 성과 달성 시 보너스를 약속하며 팀원들을 독려했다.", "label_id": "M02-01", "label_name": "내재적 동기 자극", "label_type": "positive", "data_type": "hard_negative", "is_negative_of": "M02-01"},
  {"text": "결과가 좋으면 팀 회식 지원해드리겠습니다.", "label_id": "M02-01", "label_name": "내재적 동기 자극", "label_type": "positive", "data_type": "hard_negative", "is_negative_of": "M02-01"},

  {"text": "외부 교육 비용을 지원해드리겠습니다. 원하시는 강의 있으면 말씀해주세요.", "label_id": "M02-02", "label_name": "성장 기회 제공", "label_type": "positive", "data_type": "clean"},
  {"text": "이번 프로젝트 리드를 맡아보세요. 성장할 수 있는 좋은 기회입니다.", "label_id": "M02-02", "label_name": "성장 기회 제공", "label_type": "positive", "data_type": "clean"},
  {"text": "팀장이 팀원에게 외부 컨퍼런스 참가 기회를 정기적으로 제공했다.", "label_id": "M02-02", "label_name": "성장 기회 제공", "label_type": "positive", "data_type": "clean"},
  {"text": "새로운 기술을 배울 수 있는 사이드 프로젝트를 업무 시간 20%로 할 수 있도록 허용하겠습니다.", "label_id": "M02-02", "label_name": "성장 기회 제공", "label_type": "positive", "data_type": "clean"},
  {"text": "멘토를 연결해드릴게요. 월 1회 정기적으로 만나서 커리어 방향을 논의해보세요.", "label_id": "M02-02", "label_name": "성장 기회 제공", "label_type": "positive", "data_type": "clean"},
  {"text": "이 업무가 지금은 낯설겠지만 6개월 뒤엔 강점이 될 겁니다. 지원하겠습니다.", "label_id": "M02-02", "label_name": "성장 기회 제공", "label_type": "positive", "data_type": "clean"},
  {"text": "팀원들이 스스로 원하는 기술 스택을 공부할 수 있도록 학습 예산을 개인당 연 50만 원 배정했다.", "label_id": "M02-02", "label_name": "성장 기회 제공", "label_type": "positive", "data_type": "clean"},
  {"text": "어떤 역량을 키우고 싶으신가요? 그에 맞는 기회를 찾아드리겠습니다.", "label_id": "M02-02", "label_name": "성장 기회 제공", "label_type": "positive", "data_type": "clean"},
  {"text": "이번에 새로운 도메인을 담당하게 해드릴게요. 익숙하진 않겠지만 성장 기회입니다.", "label_id": "M02-02", "label_name": "성장 기회 제공", "label_type": "positive", "data_type": "clean"},
  {"text": "팀장이 팀원의 역량 개발 계획을 분기마다 함께 수립하고 지원 방안을 논의했다.", "label_id": "M02-02", "label_name": "성장 기회 제공", "label_type": "positive", "data_type": "clean"},
  {"text": "지금 하는 일만 잘 해주세요. 다른 건 나중에 생각합시다.", "label_id": "M02-02", "label_name": "성장 기회 제공", "label_type": "positive", "data_type": "hard_negative", "is_negative_of": "M02-02"},
  {"text": "교육 신청했는데 업무가 바빠서 승인을 보류했습니다.", "label_id": "M02-02", "label_name": "성장 기회 제공", "label_type": "positive", "data_type": "hard_negative", "is_negative_of": "M02-02"},
  {"text": "같은 업무를 반복해서 해야 전문성이 생깁니다. 변화는 나중에 생각하세요.", "label_id": "M02-02", "label_name": "성장 기회 제공", "label_type": "positive", "data_type": "hard_negative", "is_negative_of": "M02-02"},
  {"text": "팀원 성장보다 당장 성과가 중요합니다.", "label_id": "M02-02", "label_name": "성장 기회 제공", "label_type": "positive", "data_type": "hard_negative", "is_negative_of": "M02-02"},
  {"text": "교육은 본인 시간에 알아서 하세요.", "label_id": "M02-02", "label_name": "성장 기회 제공", "label_type": "positive", "data_type": "hard_negative", "is_negative_of": "M02-02"},

  {"text": "이번에 정말 수고 많으셨습니다. 어려운 상황에서 끝까지 해내셨네요.", "label_id": "M02-03", "label_name": "격려 및 인정", "label_type": "positive", "data_type": "clean"},
  {"text": "지난 주 발표 정말 잘하셨어요. 준비를 많이 하신 게 느껴졌습니다.", "label_id": "M02-03", "label_name": "격려 및 인정", "label_type": "positive", "data_type": "clean"},
  {"text": "팀장이 전체 회의에서 특정 팀원의 기여를 이름을 언급하며 공개적으로 칭찬했다.", "label_id": "M02-03", "label_name": "격려 및 인정", "label_type": "positive", "data_type": "clean"},
  {"text": "결과가 좋든 나쁘든, 이번에 여러분이 보여준 노력은 정말 대단했습니다.", "label_id": "M02-03", "label_name": "격려 및 인정", "label_type": "positive", "data_type": "clean"},
  {"text": "이 작업 굉장히 꼼꼼하게 처리해주셨네요. 덕분에 다음 단계가 훨씬 수월해졌습니다.", "label_id": "M02-03", "label_name": "격려 및 인정", "label_type": "positive", "data_type": "clean"},
  {"text": "힘든 기간이었는데 잘 버텨주셨습니다. 정말 고맙습니다.", "label_id": "M02-03", "label_name": "격려 및 인정", "label_type": "positive", "data_type": "clean"},
  {"text": "팀원의 작은 기여도 놓치지 않고 인정해주는 팀장 덕분에 팀 분위기가 긍정적으로 유지됐다.", "label_id": "M02-03", "label_name": "격려 및 인정", "label_type": "positive", "data_type": "clean"},
  {"text": "오늘 미팅에서 제안한 아이디어 정말 좋았어요. 그 방향으로 더 발전시켜봅시다.", "label_id": "M02-03", "label_name": "격려 및 인정", "label_type": "positive", "data_type": "clean"},
  {"text": "이 팀원이 있어서 팀이 한 단계 올라갔다고 생각합니다.", "label_id": "M02-03", "label_name": "격려 및 인정", "label_type": "positive", "data_type": "clean"},
  {"text": "어려운 고객사 대응을 침착하게 잘 처리해주셨습니다. 덕분에 관계가 유지됐습니다.", "label_id": "M02-03", "label_name": "격려 및 인정", "label_type": "positive", "data_type": "clean"},
  {"text": "그 정도는 당연히 해야 하는 거 아닌가요?", "label_id": "M02-03", "label_name": "격려 및 인정", "label_type": "positive", "data_type": "hard_negative", "is_negative_of": "M02-03"},
  {"text": "결과가 좋았으니 됐습니다. 다음 거 시작합시다.", "label_id": "M02-03", "label_name": "격려 및 인정", "label_type": "positive", "data_type": "hard_negative", "is_negative_of": "M02-03"},
  {"text": "수고했어요. 근데 왜 이 부분은 이렇게 했어요?", "label_id": "M02-03", "label_name": "격려 및 인정", "label_type": "positive", "data_type": "hard_negative", "is_negative_of": "M02-03"},
  {"text": "다들 열심히 했는데 결과가 이게 뭡니까.", "label_id": "M02-03", "label_name": "격려 및 인정", "label_type": "positive", "data_type": "hard_negative", "is_negative_of": "M02-03"},
  {"text": "노력은 알겠는데 성과가 없으면 의미가 없습니다.", "label_id": "M02-03", "label_name": "격려 및 인정", "label_type": "positive", "data_type": "hard_negative", "is_negative_of": "M02-03"},

  {"text": "오전 10시까지는 회의 없이 집중 작업 시간으로 운영하겠습니다.", "label_id": "M02-04", "label_name": "목표 몰입 유도", "label_type": "positive", "data_type": "clean"},
  {"text": "이 프로젝트 기간 동안은 다른 업무 요청을 최소화해드리겠습니다. 집중해주세요.", "label_id": "M02-04", "label_name": "목표 몰입 유도", "label_type": "positive", "data_type": "clean"},
  {"text": "팀장이 불필요한 보고 절차를 줄여 팀원들이 핵심 업무에 집중할 수 있는 환경을 만들었다.", "label_id": "M02-04", "label_name": "목표 몰입 유도", "label_type": "positive", "data_type": "clean"},
  {"text": "슬랙 알림은 업무 시간 외에도 확인하지 않아도 됩니다. 집중하세요.", "label_id": "M02-04", "label_name": "목표 몰입 유도", "label_type": "positive", "data_type": "clean"},
  {"text": "이번 주는 이 기능 하나에만 집중합시다. 다른 요청은 다음 주로 미루겠습니다.", "label_id": "M02-04", "label_name": "목표 몰입 유도", "label_type": "positive", "data_type": "clean"},
  {"text": "방해 요소 없이 몰입할 수 있는 환경을 만드는 것이 리더의 역할이라고 생각합니다.", "label_id": "M02-04", "label_name": "목표 몰입 유도", "label_type": "positive", "data_type": "clean"},
  {"text": "주간 정기 보고를 격주로 바꿔서 실무 시간을 확보해드리겠습니다.", "label_id": "M02-04", "label_name": "목표 몰입 유도", "label_type": "positive", "data_type": "clean"},
  {"text": "오늘 오후는 외부 미팅 없이 팀 전체가 개발에만 집중하는 날로 지정하겠습니다.", "label_id": "M02-04", "label_name": "목표 몰입 유도", "label_type": "positive", "data_type": "clean"},
  {"text": "불필요한 회의를 줄이고 팀원들이 진짜 일에 몰입할 수 있도록 하는 것이 제 역할입니다.", "label_id": "M02-04", "label_name": "목표 몰입 유도", "label_type": "positive", "data_type": "clean"},
  {"text": "이 업무 중에는 다른 사람의 요청을 거절해도 됩니다. 제가 방패가 되겠습니다.", "label_id": "M02-04", "label_name": "목표 몰입 유도", "label_type": "positive", "data_type": "clean"},
  {"text": "오늘 오전에 긴급 보고도 있고 미팅도 세 개입니다. 그 사이에 개발도 해주세요.", "label_id": "M02-04", "label_name": "목표 몰입 유도", "label_type": "positive", "data_type": "hard_negative", "is_negative_of": "M02-04"},
  {"text": "여러 업무를 동시에 처리할 수 있어야 합니다. 멀티태스킹이 기본입니다.", "label_id": "M02-04", "label_name": "목표 몰입 유도", "label_type": "positive", "data_type": "hard_negative", "is_negative_of": "M02-04"},
  {"text": "개발하면서 CS 문의도 같이 봐주세요.", "label_id": "M02-04", "label_name": "목표 몰입 유도", "label_type": "positive", "data_type": "hard_negative", "is_negative_of": "M02-04"},
  {"text": "집중 시간을 드리고 싶지만 지금은 급한 게 너무 많아서요.", "label_id": "M02-04", "label_name": "목표 몰입 유도", "label_type": "positive", "data_type": "hard_negative", "is_negative_of": "M02-04"},
  {"text": "수시로 진행 상황 공유해주세요. 30분마다 업데이트 부탁드립니다.", "label_id": "M02-04", "label_name": "목표 몰입 유도", "label_type": "positive", "data_type": "hard_negative", "is_negative_of": "M02-04"},

  {"text": "이 문제를 다른 각도에서 바라보면 어떨까요. 우리가 잘못된 문제를 풀고 있는 건 아닐까요?", "label_id": "M03-01", "label_name": "문제 재정의", "label_type": "positive", "data_type": "clean"},
  {"text": "고객이 원하는 건 빠른 배송이 아니라 불확실성 해소일 수 있습니다. 문제 자체를 다시 정의해봅시다.", "label_id": "M03-01", "label_name": "문제 재정의", "label_type": "positive", "data_type": "clean"},
  {"text": "팀장이 회의에서 문제의 본질이 무엇인지를 먼저 합의하자며 논의 방향을 전환시켰다.", "label_id": "M03-01", "label_name": "문제 재정의", "label_type": "positive", "data_type": "clean"},
  {"text": "진짜 문제는 속도가 아니라 신뢰일 수 있어요. 그 관점에서 다시 접근해봅시다.", "label_id": "M03-01", "label_name": "문제 재정의", "label_type": "positive", "data_type": "clean"},
  {"text": "우리가 해결하려는 게 뭔지 한 문장으로 다시 정리해봅시다.", "label_id": "M03-01", "label_name": "문제 재정의", "label_type": "positive", "data_type": "clean"},
  {"text": "해결책을 먼저 고민하기 전에 문제가 맞게 정의됐는지 확인하는 게 순서입니다.", "label_id": "M03-01", "label_name": "문제 재정의", "label_type": "positive", "data_type": "clean"},
  {"text": "고객 관점에서 이 상황을 다시 보면 어떻게 느껴질까요? 관점을 바꿔봅시다.", "label_id": "M03-01", "label_name": "문제 재정의", "label_type": "positive", "data_type": "clean"},
  {"text": "문제가 틀렸으면 아무리 좋은 해결책도 소용없습니다. 지금부터 문제부터 다시 정의합시다.", "label_id": "M03-01", "label_name": "문제 재정의", "label_type": "positive", "data_type": "clean"},
  {"text": "표면에 보이는 증상이 아니라 근본 원인이 무엇인지를 먼저 찾아야 합니다.", "label_id": "M03-01", "label_name": "문제 재정의", "label_type": "positive", "data_type": "clean"},
  {"text": "팀장이 기존 프레임을 벗어나 완전히 다른 시각에서 문제를 바라보자고 제안했다.", "label_id": "M03-01", "label_name": "문제 재정의", "label_type": "positive", "data_type": "clean"},
  {"text": "이 방법이 항상 통했으니까 이번에도 같은 방식으로 해결합시다.", "label_id": "M03-01", "label_name": "문제 재정의", "label_type": "positive", "data_type": "hard_negative", "is_negative_of": "M03-01"},
  {"text": "문제는 이미 파악됐습니다. 해결책 찾는 데 집중합시다.", "label_id": "M03-01", "label_name": "문제 재정의", "label_type": "positive", "data_type": "hard_negative", "is_negative_of": "M03-01"},
  {"text": "예전에 했던 방식 그대로 하면 됩니다. 검증된 방법입니다.", "label_id": "M03-01", "label_name": "문제 재정의", "label_type": "positive", "data_type": "hard_negative", "is_negative_of": "M03-01"},
  {"text": "팀장이 기존 방식을 고집하며 새로운 관점 제시를 차단했다.", "label_id": "M03-01", "label_name": "문제 재정의", "label_type": "positive", "data_type": "hard_negative", "is_negative_of": "M03-01"},
  {"text": "문제는 명확하니 빨리 결론 내고 실행합시다.", "label_id": "M03-01", "label_name": "문제 재정의", "label_type": "positive", "data_type": "hard_negative", "is_negative_of": "M03-01"},

  {"text": "왜 항상 이 방식으로 해야 하는 건가요? 한번 의심해봅시다.", "label_id": "M03-02", "label_name": "창의적 질문", "label_type": "positive", "data_type": "clean"},
  {"text": "우리가 당연하다고 여기는 전제 중 하나를 제거하면 어떻게 될까요?", "label_id": "M03-02", "label_name": "창의적 질문", "label_type": "positive", "data_type": "clean"},
  {"text": "팀장이 회의에서 왜 이 순서대로 해야 하죠?라고 물으며 팀의 고정관념을 흔들었다.", "label_id": "M03-02", "label_name": "창의적 질문", "label_type": "positive", "data_type": "clean"},
  {"text": "만약 예산이 10배라면 어떻게 접근할 건가요? 역으로 생각해봅시다.", "label_id": "M03-02", "label_name": "창의적 질문", "label_type": "positive", "data_type": "clean"},
  {"text": "경쟁사가 없다고 가정하면 우리는 뭘 다르게 할 수 있을까요?", "label_id": "M03-02", "label_name": "창의적 질문", "label_type": "positive", "data_type": "clean"},
  {"text": "이게 정말 최선인지 한번 의심해봐야 합니다. 당연한 건 없습니다.", "label_id": "M03-02", "label_name": "창의적 질문", "label_type": "positive", "data_type": "clean"},
  {"text": "도전적인 질문을 자주 던지는 팀장 덕분에 팀 전체의 사고가 유연해지는 분위기가 형성됐다.", "label_id": "M03-02", "label_name": "창의적 질문", "label_type": "positive", "data_type": "clean"},
  {"text": "고객이 이 제품을 쓰지 않는 이유가 뭘까요? 반대로 생각해봅시다.", "label_id": "M03-02", "label_name": "창의적 질문", "label_type": "positive", "data_type": "clean"},
  {"text": "지금 방식이 왜 옳다고 생각하시나요? 그 근거를 한번 따져봅시다.", "label_id": "M03-02", "label_name": "창의적 질문", "label_type": "positive", "data_type": "clean"},
  {"text": "10년 후 이 결정을 돌아본다면 어떻게 평가할 것 같나요?", "label_id": "M03-02", "label_name": "창의적 질문", "label_type": "positive", "data_type": "clean"},
  {"text": "질문이 많으면 회의가 길어집니다. 결론부터 내고 질문은 나중에 합시다.", "label_id": "M03-02", "label_name": "창의적 질문", "label_type": "positive", "data_type": "hard_negative", "is_negative_of": "M03-02"},
  {"text": "이미 검토한 내용입니다. 다시 의심할 필요 없어요.", "label_id": "M03-02", "label_name": "창의적 질문", "label_type": "positive", "data_type": "hard_negative", "is_negative_of": "M03-02"},
  {"text": "왜 이렇게 했어요? 제대로 한 게 맞아요?", "label_id": "M03-02", "label_name": "창의적 질문", "label_type": "positive", "data_type": "hard_negative", "is_negative_of": "M03-02"},
  {"text": "팀장이 팀원에게 설명을 요구하며 추궁하는 질문을 반복했다.", "label_id": "M03-02", "label_name": "창의적 질문", "label_type": "positive", "data_type": "hard_negative", "is_negative_of": "M03-02"},
  {"text": "지금 방식이 맞는 겁니다. 굳이 다시 생각할 필요 없습니다.", "label_id": "M03-02", "label_name": "창의적 질문", "label_type": "positive", "data_type": "hard_negative", "is_negative_of": "M03-02"}
]
