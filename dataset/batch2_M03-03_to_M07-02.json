[
  {"text": "기존 방식 대신 완전히 다른 방법을 한번 시도해봅시다. 실패해도 괜찮습니다.", "label_id": "M03-03", "label_name": "새로운 접근 유도", "label_type": "positive", "data_type": "clean"},
  {"text": "다른 팀에서 사용하는 방식을 우리도 도입해보는 건 어떨까요?", "label_id": "M03-03", "label_name": "새로운 접근 유도", "label_type": "positive", "data_type": "clean"},
  {"text": "팀장이 전례 없는 방식으로 프로젝트를 진행해보자고 제안하며 팀원들의 도전 의식을 자극했다.", "label_id": "M03-03", "label_name": "새로운 접근 유도", "label_type": "positive", "data_type": "clean"},
  {"text": "지금껏 아무도 시도하지 않은 방법입니다. 우리가 먼저 해봅시다.", "label_id": "M03-03", "label_name": "새로운 접근 유도", "label_type": "positive", "data_type": "clean"},
  {"text": "이번에는 완전히 다른 각도에서 접근해보는 것이 좋겠습니다.", "label_id": "M03-03", "label_name": "새로운 접근 유도", "label_type": "positive", "data_type": "clean"},
  {"text": "실험적으로 해봅시다. 결과가 어떻든 배움이 있을 겁니다.", "label_id": "M03-03", "label_name": "새로운 접근 유도", "label_type": "positive", "data_type": "clean"},
  {"text": "팀원들이 새로운 기술 스택을 적용하자고 제안했을 때 팀장이 적극적으로 지지했다.", "label_id": "M03-03", "label_name": "새로운 접근 유도", "label_type": "positive", "data_type": "clean"},
  {"text": "기존 틀을 벗어난 방식으로 시도해보는 것이 좋겠습니다. 지원하겠습니다.", "label_id": "M03-03", "label_name": "새로운 접근 유도", "label_type": "positive", "data_type": "clean"},
  {"text": "지금 방식이 최선이 아닐 수 있습니다. 완전히 새로운 접근을 환영합니다.", "label_id": "M03-03", "label_name": "새로운 접근 유도", "label_type": "positive", "data_type": "clean"},
  {"text": "누군가 전혀 다른 방법을 제안했을 때 팀 전체가 흥미롭게 검토하는 분위기가 형성됐다.", "label_id": "M03-03", "label_name": "새로운 접근 유도", "label_type": "positive", "data_type": "clean"},
  {"text": "검증된 방법을 쓰는 게 맞습니다. 괜히 새로운 시도를 해서 리스크를 만들 필요 없어요.", "label_id": "M03-03", "label_name": "새로운 접근 유도", "label_type": "positive", "data_type": "hard_negative", "is_negative_of": "M03-03"},
  {"text": "지금까지 해온 방식이 있으니 그대로 합시다.", "label_id": "M03-03", "label_name": "새로운 접근 유도", "label_type": "positive", "data_type": "hard_negative", "is_negative_of": "M03-03"},
  {"text": "새로운 방법은 나중에 여유가 생기면 검토하겠습니다.", "label_id": "M03-03", "label_name": "새로운 접근 유도", "label_type": "positive", "data_type": "hard_negative", "is_negative_of": "M03-03"},
  {"text": "팀장이 팀원의 새로운 접근 제안을 리스크를 이유로 즉시 반려했다.", "label_id": "M03-03", "label_name": "새로운 접근 유도", "label_type": "positive", "data_type": "hard_negative", "is_negative_of": "M03-03"},
  {"text": "우리 팀 방식이 따로 있으니 그것만 따라주세요.", "label_id": "M03-03", "label_name": "새로운 접근 유도", "label_type": "positive", "data_type": "hard_negative", "is_negative_of": "M03-03"},

  {"text": "팀장의 말 한마디가 분위기를 바꿨다. 그 존재감 하나만으로도 팀이 움직였다.", "label_id": "M04-01", "label_name": "카리스마적 영향력", "label_type": "positive", "data_type": "clean"},
  {"text": "어떤 강압도 없이 팀원들이 자발적으로 팀장의 방향을 따르는 분위기가 자연스럽게 형성됐다.", "label_id": "M04-01", "label_name": "카리스마적 영향력", "label_type": "positive", "data_type": "clean"},
  {"text": "설득력 있는 발표 하나로 전체 회의실의 동의를 이끌어냈다.", "label_id": "M04-01", "label_name": "카리스마적 영향력", "label_type": "positive", "data_type": "clean"},
  {"text": "리더의 확신 있는 태도가 팀 전체에 신뢰를 심어줬다.", "label_id": "M04-01", "label_name": "카리스마적 영향력", "label_type": "positive", "data_type": "clean"},
  {"text": "힘든 상황에서도 팀원들이 따르는 이유는 그 리더에게서 믿음이 느껴지기 때문이었다.", "label_id": "M04-01", "label_name": "카리스마적 영향력", "label_type": "positive", "data_type": "clean"},
  {"text": "리더가 입장한 순간 회의실의 분위기가 달라졌다. 그만큼 존재감이 강했다.", "label_id": "M04-01", "label_name": "카리스마적 영향력", "label_type": "positive", "data_type": "clean"},
  {"text": "반대 의견이 많았지만 팀장의 설득으로 결국 모두가 방향을 전환하는 데 동의했다.", "label_id": "M04-01", "label_name": "카리스마적 영향력", "label_type": "positive", "data_type": "clean"},
  {"text": "그 리더의 말에는 특유의 무게감이 있어서 듣는 사람이 자연스럽게 귀를 기울이게 됐다.", "label_id": "M04-01", "label_name": "카리스마적 영향력", "label_type": "positive", "data_type": "clean"},
  {"text": "어려운 결정을 내릴 때도 팀원들이 믿고 따랐던 건 평소 쌓인 신뢰 덕분이었다.", "label_id": "M04-01", "label_name": "카리스마적 영향력", "label_type": "positive", "data_type": "clean"},
  {"text": "그 리더가 있으면 팀의 에너지가 달라진다는 말이 팀원들 사이에서 자연스럽게 나왔다.", "label_id": "M04-01", "label_name": "카리스마적 영향력", "label_type": "positive", "data_type": "clean"},
  {"text": "내가 팀장이니까 내 말대로 하세요. 이유는 없습니다.", "label_id": "M04-01", "label_name": "카리스마적 영향력", "label_type": "positive", "data_type": "hard_negative", "is_negative_of": "M04-01"},
  {"text": "직급이 높은 사람 말을 따르는 게 당연한 겁니다.", "label_id": "M04-01", "label_name": "카리스마적 영향력", "label_type": "positive", "data_type": "hard_negative", "is_negative_of": "M04-01"},
  {"text": "반대하면 어떻게 될지 다들 알죠? 그러니 따라주세요.", "label_id": "M04-01", "label_name": "카리스마적 영향력", "label_type": "positive", "data_type": "hard_negative", "is_negative_of": "M04-01"},
  {"text": "팀장이 강압적인 태도로 팀원들의 동의를 억지로 이끌어냈다.", "label_id": "M04-01", "label_name": "카리스마적 영향력", "label_type": "positive", "data_type": "hard_negative", "is_negative_of": "M04-01"},
  {"text": "권한을 이용해 반대 의견을 차단하고 결정을 밀어붙였다.", "label_id": "M04-01", "label_name": "카리스마적 영향력", "label_type": "positive", "data_type": "hard_negative", "is_negative_of": "M04-01"},

  {"text": "내가 먼저 야근하겠습니다. 팀원들은 퇴근해도 됩니다.", "label_id": "M04-02", "label_name": "롤모델 행동", "label_type": "positive", "data_type": "clean"},
  {"text": "팀장이 회의 시간을 스스로 지키며 팀원들에게 시간 약속의 중요성을 몸으로 보여줬다.", "label_id": "M04-02", "label_name": "롤모델 행동", "label_type": "positive", "data_type": "clean"},
  {"text": "제가 먼저 새로운 도구를 써보겠습니다. 익숙해지면 팀 전체에 공유하겠습니다.", "label_id": "M04-02", "label_name": "롤모델 행동", "label_type": "positive", "data_type": "clean"},
  {"text": "직접 고객에게 사과하겠습니다. 팀장으로서 제 책임입니다.", "label_id": "M04-02", "label_name": "롤모델 행동", "label_type": "positive", "data_type": "clean"},
  {"text": "팀장이 문서화를 강조하면서 본인부터 모든 의사결정 과정을 기록하는 모범을 보였다.", "label_id": "M04-02", "label_name": "롤모델 행동", "label_type": "positive", "data_type": "clean"},
  {"text": "제가 먼저 솔직한 피드백을 요청합니다. 저도 개선할 부분이 있을 테니까요.", "label_id": "M04-02", "label_name": "롤모델 행동", "label_type": "positive", "data_type": "clean"},
  {"text": "팀원들에게 정시 퇴근을 독려하면서 팀장 본인도 매일 정시에 퇴근하는 모습을 보여줬다.", "label_id": "M04-02", "label_name": "롤모델 행동", "label_type": "positive", "data_type": "clean"},
  {"text": "제가 먼저 실수를 인정하겠습니다. 그래야 팀원들도 편하게 말할 수 있으니까요.", "label_id": "M04-02", "label_name": "롤모델 행동", "label_type": "positive", "data_type": "clean"},
  {"text": "리더가 가장 힘든 고객사 미팅을 직접 맡으며 어려운 일은 제가 앞장서겠다는 의지를 보여줬다.", "label_id": "M04-02", "label_name": "롤모델 행동", "label_type": "positive", "data_type": "clean"},
  {"text": "말로만 하지 않겠습니다. 제가 직접 보여드리겠습니다.", "label_id": "M04-02", "label_name": "롤모델 행동", "label_type": "positive", "data_type": "clean"},
  {"text": "팀원들은 야근해야 하지만 저는 오늘 일찍 퇴근하겠습니다.", "label_id": "M04-02", "label_name": "롤모델 행동", "label_type": "positive", "data_type": "hard_negative", "is_negative_of": "M04-02"},
  {"text": "내가 말하는 대로 하면 됩니다. 내가 하는 대로 따라 할 필요는 없어요.", "label_id": "M04-02", "label_name": "롤모델 행동", "label_type": "positive", "data_type": "hard_negative", "is_negative_of": "M04-02"},
  {"text": "규칙은 팀원들이 지켜야 하는 겁니다. 저는 예외입니다.", "label_id": "M04-02", "label_name": "롤모델 행동", "label_type": "positive", "data_type": "hard_negative", "is_negative_of": "M04-02"},
  {"text": "팀장이 팀원들에게 문서화를 강요하면서 본인은 구두로만 소통했다.", "label_id": "M04-02", "label_name": "롤모델 행동", "label_type": "positive", "data_type": "hard_negative", "is_negative_of": "M04-02"},
  {"text": "어려운 업무는 팀원이 하고 저는 방향 제시만 하겠습니다.", "label_id": "M04-02", "label_name": "롤모델 행동", "label_type": "positive", "data_type": "hard_negative", "is_negative_of": "M04-02"},

  {"text": "지금 방식으로는 더 이상 경쟁할 수 없습니다. 변화하지 않으면 도태됩니다.", "label_id": "M05-01", "label_name": "변화 필요 성명", "label_type": "positive", "data_type": "clean"},
  {"text": "왜 지금 바뀌어야 하는지 솔직하게 말씀드리겠습니다. 현재 방식의 문제점이 있습니다.", "label_id": "M05-01", "label_name": "변화 필요 성명", "label_type": "positive", "data_type": "clean"},
  {"text": "팀장이 현재 방식의 한계를 데이터로 보여주며 변화의 필요성을 설득력 있게 전달했다.", "label_id": "M05-01", "label_name": "변화 필요 성명", "label_type": "positive", "data_type": "clean"},
  {"text": "지금 이대로 가면 1년 후 우리가 어디에 있을지 냉정하게 바라봅시다.", "label_id": "M05-01", "label_name": "변화 필요 성명", "label_type": "positive", "data_type": "clean"},
  {"text": "시장이 바뀌었는데 우리만 그대로입니다. 변화가 선택이 아닌 필수가 됐습니다.", "label_id": "M05-01", "label_name": "변화 필요 성명", "label_type": "positive", "data_type": "clean"},
  {"text": "불편하더라도 솔직히 말씀드려야 할 것 같습니다. 지금 우리에게는 변화가 필요합니다.", "label_id": "M05-01", "label_name": "변화 필요 성명", "label_type": "positive", "data_type": "clean"},
  {"text": "현재 방식의 문제점을 인식하고 있는 사람이 저뿐이 아닐 겁니다. 이제 이야기해봅시다.", "label_id": "M05-01", "label_name": "변화 필요 성명", "label_type": "positive", "data_type": "clean"},
  {"text": "경쟁사는 이미 2년 전에 전환했습니다. 우리가 늦었지만 지금이라도 시작해야 합니다.", "label_id": "M05-01", "label_name": "변화 필요 성명", "label_type": "positive", "data_type": "clean"},
  {"text": "팀장이 외부 환경 변화를 분석하며 지금 바뀌지 않으면 기회가 없다고 강조했다.", "label_id": "M05-01", "label_name": "변화 필요 성명", "label_type": "positive", "data_type": "clean"},
  {"text": "이 변화가 불편하다는 걸 압니다. 하지만 지금 하지 않으면 더 큰 고통이 옵니다.", "label_id": "M05-01", "label_name": "변화 필요 성명", "label_type": "positive", "data_type": "clean"},
  {"text": "지금 방식도 나쁘지 않습니다. 굳이 바꿀 필요가 있을까요?", "label_id": "M05-01", "label_name": "변화 필요 성명", "label_type": "positive", "data_type": "hard_negative", "is_negative_of": "M05-01"},
  {"text": "변화는 리스크가 크니 안정적으로 가는 게 맞습니다.", "label_id": "M05-01", "label_name": "변화 필요 성명", "label_type": "positive", "data_type": "hard_negative", "is_negative_of": "M05-01"},
  {"text": "지금 잘 돌아가고 있는데 왜 바꿔야 합니까?", "label_id": "M05-01", "label_name": "변화 필요 성명", "label_type": "positive", "data_type": "hard_negative", "is_negative_of": "M05-01"},
  {"text": "변화 얘기는 나중에 합시다. 지금은 현재 업무에 집중해야 합니다.", "label_id": "M05-01", "label_name": "변화 필요 성명", "label_type": "positive", "data_type": "hard_negative", "is_negative_of": "M05-01"},
  {"text": "팀장이 변화 필요성을 언급했지만 구체적인 근거나 설명 없이 지나쳤다.", "label_id": "M05-01", "label_name": "변화 필요 성명", "label_type": "positive", "data_type": "hard_negative", "is_negative_of": "M05-01"},

  {"text": "변화를 위한 예산과 시간을 드리겠습니다. 필요한 게 있으면 말씀해주세요.", "label_id": "M05-02", "label_name": "변화 실행 장려", "label_type": "positive", "data_type": "clean"},
  {"text": "새로운 프로세스로 전환할 수 있도록 제가 직접 지원하겠습니다.", "label_id": "M05-02", "label_name": "변화 실행 장려", "label_type": "positive", "data_type": "clean"},
  {"text": "팀장이 새로운 도구 도입을 위해 파일럿 팀을 직접 구성하고 지원 체계를 만들었다.", "label_id": "M05-02", "label_name": "변화 실행 장려", "label_type": "positive", "data_type": "clean"},
  {"text": "말로만 변화를 이야기하지 않겠습니다. 실제로 실행할 수 있도록 함께 움직이겠습니다.", "label_id": "M05-02", "label_name": "변화 실행 장려", "label_type": "positive", "data_type": "clean"},
  {"text": "변화에 동참해주셔서 감사합니다. 실행하면서 어려운 점이 생기면 바로 말씀해주세요.", "label_id": "M05-02", "label_name": "변화 실행 장려", "label_type": "positive", "data_type": "clean"},
  {"text": "이번 변화를 실행하는 팀에 리소스를 우선 배분하겠습니다.", "label_id": "M05-02", "label_name": "변화 실행 장려", "label_type": "positive", "data_type": "clean"},
  {"text": "파일럿 프로젝트를 함께 진행합시다. 결과를 보고 전체 확산 여부를 결정하겠습니다.", "label_id": "M05-02", "label_name": "변화 실행 장려", "label_type": "positive", "data_type": "clean"},
  {"text": "변화 실행에 참여하는 팀원들의 시도를 적극 지지하는 분위기가 팀 전체에 형성됐다.", "label_id": "M05-02", "label_name": "변화 실행 장려", "label_type": "positive", "data_type": "clean"},
  {"text": "새로운 방식으로 전환하는 과정에서 생기는 시행착오는 제가 함께 책임지겠습니다.", "label_id": "M05-02", "label_name": "변화 실행 장려", "label_type": "positive", "data_type": "clean"},
  {"text": "변화에 앞장서는 분들에게 충분한 지원을 드리겠습니다. 혼자 하지 않아도 됩니다.", "label_id": "M05-02", "label_name": "변화 실행 장려", "label_type": "positive", "data_type": "clean"},
  {"text": "변화가 필요하다고 했으니 알아서 하세요. 방법은 본인이 찾으세요.", "label_id": "M05-02", "label_name": "변화 실행 장려", "label_type": "positive", "data_type": "hard_negative", "is_negative_of": "M05-02"},
  {"text": "말로만 변화를 강조했지만 실제 지원이나 자원 배분은 이루어지지 않았다.", "label_id": "M05-02", "label_name": "변화 실행 장려", "label_type": "positive", "data_type": "hard_negative", "is_negative_of": "M05-02"},
  {"text": "변화하라고 했는데 왜 아직도 그대로입니까?", "label_id": "M05-02", "label_name": "변화 실행 장려", "label_type": "positive", "data_type": "hard_negative", "is_negative_of": "M05-02"},
  {"text": "변화는 팀원들이 알아서 해야 합니다. 저는 방향만 제시합니다.", "label_id": "M05-02", "label_name": "변화 실행 장려", "label_type": "positive", "data_type": "hard_negative", "is_negative_of": "M05-02"},
  {"text": "팀장이 변화를 주도하라고 했지만 막상 시도하면 뒷받침이 없었다.", "label_id": "M05-02", "label_name": "변화 실행 장려", "label_type": "positive", "data_type": "hard_negative", "is_negative_of": "M05-02"},

  {"text": "우리 팀에서는 새로운 시도를 두려워하지 않아도 됩니다. 실패해도 괜찮습니다.", "label_id": "M05-03", "label_name": "변화 문화 조성", "label_type": "positive", "data_type": "clean"},
  {"text": "실험하고 배우는 문화를 만들고 싶습니다. 시도 자체가 성과입니다.", "label_id": "M05-03", "label_name": "변화 문화 조성", "label_type": "positive", "data_type": "clean"},
  {"text": "팀장이 실패를 처벌하지 않는 문화를 꾸준히 만들어온 덕분에 팀원들이 도전을 두려워하지 않게 됐다.", "label_id": "M05-03", "label_name": "변화 문화 조성", "label_type": "positive", "data_type": "clean"},
  {"text": "매주 금요일 오후는 새로운 아이디어를 실험하는 시간으로 운영하겠습니다.", "label_id": "M05-03", "label_name": "변화 문화 조성", "label_type": "positive", "data_type": "clean"},
  {"text": "변화를 거부하는 문화가 가장 큰 적입니다. 도전하는 사람을 응원하는 팀을 만들겠습니다.", "label_id": "M05-03", "label_name": "변화 문화 조성", "label_type": "positive", "data_type": "clean"},
  {"text": "새로운 시도를 한 팀원을 결과와 관계없이 공개적으로 인정하는 문화가 자리 잡았다.", "label_id": "M05-03", "label_name": "변화 문화 조성", "label_type": "positive", "data_type": "clean"},
  {"text": "혁신은 허락이 필요 없습니다. 아이디어가 있으면 먼저 작게 시도해보세요.", "label_id": "M05-03", "label_name": "변화 문화 조성", "label_type": "positive", "data_type": "clean"},
  {"text": "이 팀에서는 현상 유지가 가장 위험한 선택입니다. 항상 더 나은 방법을 찾읍시다.", "label_id": "M05-03", "label_name": "변화 문화 조성", "label_type": "positive", "data_type": "clean"},
  {"text": "팀 문화 자체를 변화와 혁신을 환영하는 방향으로 바꾸는 게 제 목표입니다.", "label_id": "M05-03", "label_name": "변화 문화 조성", "label_type": "positive", "data_type": "clean"},
  {"text": "실패를 부끄러워하지 마세요. 실패한 경험을 팀 전체가 배울 수 있도록 공유해주세요.", "label_id": "M05-03", "label_name": "변화 문화 조성", "label_type": "positive", "data_type": "clean"},
  {"text": "변화를 시도했다가 실패하면 책임을 져야 합니다.", "label_id": "M05-03", "label_name": "변화 문화 조성", "label_type": "positive", "data_type": "hard_negative", "is_negative_of": "M05-03"},
  {"text": "안정적으로 운영하는 게 우리 팀 문화입니다. 굳이 실험할 필요 없습니다.", "label_id": "M05-03", "label_name": "변화 문화 조성", "label_type": "positive", "data_type": "hard_negative", "is_negative_of": "M05-03"},
  {"text": "실패한 프로젝트는 팀원 평가에 반영됩니다.", "label_id": "M05-03", "label_name": "변화 문화 조성", "label_type": "positive", "data_type": "hard_negative", "is_negative_of": "M05-03"},
  {"text": "새로운 시도는 승인이 필요합니다. 허락 없이 하면 안 됩니다.", "label_id": "M05-03", "label_name": "변화 문화 조성", "label_type": "positive", "data_type": "hard_negative", "is_negative_of": "M05-03"},
  {"text": "팀장이 겉으로는 혁신을 강조했지만 실제로 변화를 시도한 팀원을 질책했다.", "label_id": "M05-03", "label_name": "변화 문화 조성", "label_type": "positive", "data_type": "hard_negative", "is_negative_of": "M05-03"},

  {"text": "이번 프로젝트의 성공 기준을 먼저 정의합시다. 완료 시점에 무엇을 달성해야 하는지 명확히 합시다.", "label_id": "M06-01", "label_name": "목표 설정 및 기대치 명확화", "label_type": "positive", "data_type": "clean"},
  {"text": "이번 분기 팀 KPI는 신규 계약 15건, 갱신율 90% 이상입니다. 모두 확인해주세요.", "label_id": "M06-01", "label_name": "목표 설정 및 기대치 명확화", "label_type": "positive", "data_type": "clean"},
  {"text": "팀장이 각 업무의 완료 기준을 팀원과 함께 명확히 정의하는 회의를 주기적으로 진행했다.", "label_id": "M06-01", "label_name": "목표 설정 및 기대치 명확화", "label_type": "positive", "data_type": "clean"},
  {"text": "기대치를 명확히 하겠습니다. 이 업무는 목요일 오전까지 초안 제출이 기준입니다.", "label_id": "M06-01", "label_name": "목표 설정 및 기대치 명확화", "label_type": "positive", "data_type": "clean"},
  {"text": "목표가 모호하면 달성 여부도 모호해집니다. 측정 가능한 기준으로 다시 설정합시다.", "label_id": "M06-01", "label_name": "목표 설정 및 기대치 명확화", "label_type": "positive", "data_type": "clean"},
  {"text": "이번 스프린트에서 완료해야 할 항목 5가지를 지금 같이 정하겠습니다.", "label_id": "M06-01", "label_name": "목표 설정 및 기대치 명확화", "label_type": "positive", "data_type": "clean"},
  {"text": "우리가 이번 달에 달성해야 할 것과 그렇지 않은 것을 구분해서 우선순위를 잡겠습니다.", "label_id": "M06-01", "label_name": "목표 설정 및 기대치 명확화", "label_type": "positive", "data_type": "clean"},
  {"text": "팀장이 분기 초에 각 팀원의 목표를 SMART 기준으로 함께 검토하고 확정하는 시간을 가졌다.", "label_id": "M06-01", "label_name": "목표 설정 및 기대치 명확화", "label_type": "positive", "data_type": "clean"},
  {"text": "결과물의 품질 기준이 무엇인지 먼저 합의하는 것이 좋겠습니다.", "label_id": "M06-01", "label_name": "목표 설정 및 기대치 명확화", "label_type": "positive", "data_type": "clean"},
  {"text": "수치로 측정할 수 없으면 목표가 아닙니다. 숫자로 다시 정의해봅시다.", "label_id": "M06-01", "label_name": "목표 설정 및 기대치 명확화", "label_type": "positive", "data_type": "clean"},
  {"text": "잘 해주시면 됩니다. 알아서 잘 하실 거라 믿어요.", "label_id": "M06-01", "label_name": "목표 설정 및 기대치 명확화", "label_type": "positive", "data_type": "hard_negative", "is_negative_of": "M06-01"},
  {"text": "목표요? 그냥 최선을 다해주시면 됩니다.", "label_id": "M06-01", "label_name": "목표 설정 및 기대치 명확화", "label_type": "positive", "data_type": "hard_negative", "is_negative_of": "M06-01"},
  {"text": "팀장이 목표를 제시했지만 기준이 너무 모호해서 팀원들이 방향을 잡지 못했다.", "label_id": "M06-01", "label_name": "목표 설정 및 기대치 명확화", "label_type": "positive", "data_type": "hard_negative", "is_negative_of": "M06-01"},
  {"text": "대충 감 잡아서 해보세요. 보면 알 것 같으면 됩니다.", "label_id": "M06-01", "label_name": "목표 설정 및 기대치 명확화", "label_type": "positive", "data_type": "hard_negative", "is_negative_of": "M06-01"},
  {"text": "목표는 나중에 정하고 일단 시작합시다.", "label_id": "M06-01", "label_name": "목표 설정 및 기대치 명확화", "label_type": "positive", "data_type": "hard_negative", "is_negative_of": "M06-01"},

  {"text": "1단계는 요구사항 정리, 2단계는 설계 검토, 3단계는 개발 착수로 진행합시다.", "label_id": "M06-02", "label_name": "세부 실행 지침", "label_type": "positive", "data_type": "clean"},
  {"text": "상세 실행 계획을 문서로 정리해 공유하겠습니다. 각 단계별 담당자와 기한도 포함됩니다.", "label_id": "M06-02", "label_name": "세부 실행 지침", "label_type": "positive", "data_type": "clean"},
  {"text": "팀장이 프로세스를 단계별로 정리한 체크리스트를 만들어 팀 전체에 배포했다.", "label_id": "M06-02", "label_name": "세부 실행 지침", "label_type": "positive", "data_type": "clean"},
  {"text": "어떻게 해야 할지 모르는 분들을 위해 상세 가이드를 준비했습니다.", "label_id": "M06-02", "label_name": "세부 실행 지침", "label_type": "positive", "data_type": "clean"},
  {"text": "이 업무의 진행 순서를 정리하면 첫째 고객 확인, 둘째 내부 승인, 셋째 실행입니다.", "label_id": "M06-02", "label_name": "세부 실행 지침", "label_type": "positive", "data_type": "clean"},
  {"text": "막히는 부분이 생기면 이 가이드 문서를 먼저 확인해주세요.", "label_id": "M06-02", "label_name": "세부 실행 지침", "label_type": "positive", "data_type": "clean"},
  {"text": "팀장이 신규 프로세스 도입 시 단계별 매뉴얼을 직접 작성해 팀원 교육을 진행했다.", "label_id": "M06-02", "label_name": "세부 실행 지침", "label_type": "positive", "data_type": "clean"},
  {"text": "각 단계에서 확인해야 할 항목을 체크리스트로 만들었습니다. 빠짐없이 확인해주세요.", "label_id": "M06-02", "label_name": "세부 실행 지침", "label_type": "positive", "data_type": "clean"},
  {"text": "실행 전에 이 순서를 한 번 더 확인하면 실수를 줄일 수 있습니다.", "label_id": "M06-02", "label_name": "세부 실행 지침", "label_type": "positive", "data_type": "clean"},
  {"text": "프로세스를 표준화해서 누가 하든 같은 품질이 나오도록 만들겠습니다.", "label_id": "M06-02", "label_name": "세부 실행 지침", "label_type": "positive", "data_type": "clean"},
  {"text": "목표만 알려드릴게요. 어떻게 할지는 알아서 결정하세요.", "label_id": "M06-02", "label_name": "세부 실행 지침", "label_type": "positive", "data_type": "hard_negative", "is_negative_of": "M06-02"},
  {"text": "방법은 각자 알아서 합시다. 결과만 가져오세요.", "label_id": "M06-02", "label_name": "세부 실행 지침", "label_type": "positive", "data_type": "hard_negative", "is_negative_of": "M06-02"},
  {"text": "팀장이 목표만 제시하고 실행 방법에 대한 가이드는 전혀 제공하지 않았다.", "label_id": "M06-02", "label_name": "세부 실행 지침", "label_type": "positive", "data_type": "hard_negative", "is_negative_of": "M06-02"},
  {"text": "다들 경험 있으니 알아서 하시겠죠.", "label_id": "M06-02", "label_name": "세부 실행 지침", "label_type": "positive", "data_type": "hard_negative", "is_negative_of": "M06-02"},
  {"text": "절차서는 있는데 업데이트가 안 돼서 실제 업무와 맞지 않는 상태로 방치됐다.", "label_id": "M06-02", "label_name": "세부 실행 지침", "label_type": "positive", "data_type": "hard_negative", "is_negative_of": "M06-02"},

  {"text": "지난 화요일 발표에서 데이터 근거가 부족했어요. 다음엔 수치를 포함해주세요.", "label_id": "M07-01", "label_name": "구체적 피드백", "label_type": "positive", "data_type": "clean"},
  {"text": "보고서 3페이지 논리 흐름이 조금 어색했습니다. 이 부분을 이렇게 수정해보세요.", "label_id": "M07-01", "label_name": "구체적 피드백", "label_type": "positive", "data_type": "clean"},
  {"text": "팀장이 팀원의 작업물을 검토하며 어떤 부분이 잘 됐고 어떤 부분을 개선해야 하는지 구체적으로 설명했다.", "label_id": "M07-01", "label_name": "구체적 피드백", "label_type": "positive", "data_type": "clean"},
  {"text": "고객 응대 시 첫 번째 문장이 너무 길었습니다. 세 문장 이내로 줄이면 더 좋을 것 같습니다.", "label_id": "M07-01", "label_name": "구체적 피드백", "label_type": "positive", "data_type": "clean"},
  {"text": "이 기능 구현에서 예외 처리가 빠져 있었습니다. 다음번엔 이 부분을 체크리스트에 넣어주세요.", "label_id": "M07-01", "label_name": "구체적 피드백", "label_type": "positive", "data_type": "clean"},
  {"text": "어제 미팅에서 고객 질문에 답변이 늦었는데, 이 주제에 대한 사전 준비가 필요했던 것 같습니다.", "label_id": "M07-01", "label_name": "구체적 피드백", "label_type": "positive", "data_type": "clean"},
  {"text": "전체적인 방향은 좋았습니다. 다만 2번 슬라이드의 메시지가 불명확해서 청중이 혼란스러워했습니다.", "label_id": "M07-01", "label_name": "구체적 피드백", "label_type": "positive", "data_type": "clean"},
  {"text": "팀장이 1:1 피드백 세션에서 팀원의 커뮤니케이션 방식을 구체적인 사례와 함께 짚어줬다.", "label_id": "M07-01", "label_name": "구체적 피드백", "label_type": "positive", "data_type": "clean"},
  {"text": "코드 리뷰에서 이 함수가 너무 많은 역할을 하고 있습니다. 단일 책임 원칙에 맞게 분리해보세요.", "label_id": "M07-01", "label_name": "구체적 피드백", "label_type": "positive", "data_type": "clean"},
  {"text": "이번 제안서에서 경쟁사 비교 섹션이 설득력이 약했습니다. 수치 기반으로 보강하면 좋겠습니다.", "label_id": "M07-01", "label_name": "구체적 피드백", "label_type": "positive", "data_type": "clean"},
  {"text": "그냥 좀 더 잘 해주세요.", "label_id": "M07-01", "label_name": "구체적 피드백", "label_type": "positive", "data_type": "hard_negative", "is_negative_of": "M07-01"},
  {"text": "전체적으로 별로였습니다. 다시 해오세요.", "label_id": "M07-01", "label_name": "구체적 피드백", "label_type": "positive", "data_type": "hard_negative", "is_negative_of": "M07-01"},
  {"text": "왜 이렇게밖에 못 합니까? 이게 최선이에요?", "label_id": "M07-01", "label_name": "구체적 피드백", "label_type": "positive", "data_type": "hard_negative", "is_negative_of": "M07-01"},
  {"text": "팀장이 회의 중 팀원의 발표를 공개적으로 비난했다.", "label_id": "M07-01", "label_name": "구체적 피드백", "label_type": "positive", "data_type": "hard_negative", "is_negative_of": "M07-01"},
  {"text": "잘한 것 같아요. 계속 이렇게 해주세요.", "label_id": "M07-01", "label_name": "구체적 피드백", "label_type": "positive", "data_type": "hard_negative", "is_negative_of": "M07-01"},

  {"text": "이 부분을 개선하면 다음 프로젝트에서 훨씬 더 좋은 결과를 낼 수 있을 겁니다.", "label_id": "M07-02", "label_name": "성장 지향 피드백", "label_type": "positive", "data_type": "clean"},
  {"text": "앞으로 이 방향으로 접근하면 강점이 될 것입니다. 계속 발전시켜 보세요.", "label_id": "M07-02", "label_name": "성장 지향 피드백", "label_type": "positive", "data_type": "clean"},
  {"text": "팀장이 팀원의 실수를 지적하는 대신 다음에 어떻게 하면 더 잘할 수 있을지를 중심으로 피드백을 줬다.", "label_id": "M07-02", "label_name": "성장 지향 피드백", "label_type": "positive", "data_type": "clean"},
  {"text": "지금도 잘하고 있지만 이 역량을 키우면 한 단계 더 도약할 수 있습니다.", "label_id": "M07-02", "label_name": "성장 지향 피드백", "label_type": "positive", "data_type": "clean"},
  {"text": "이번에는 아쉬웠지만 이 경험이 다음번에 더 잘하기 위한 발판이 됩니다.", "label_id": "M07-02", "label_name": "성장 지향 피드백", "label_type": "positive", "data_type": "clean"},
  {"text": "현재 이 부분이 부족하지만 충분히 발전할 수 있는 영역입니다. 집중해서 키워봅시다.", "label_id": "M07-02", "label_name": "성장 지향 피드백", "label_type": "positive", "data_type": "clean"},
  {"text": "6개월 후를 생각하면 지금 이 피드백이 얼마나 중요한지 알게 될 겁니다.", "label_id": "M07-02", "label_name": "성장 지향 피드백", "label_type": "positive", "data_type": "clean"},
  {"text": "가능성이 보입니다. 이 방향으로 계속 발전해보세요.", "label_id": "M07-02", "label_name": "성장 지향 피드백", "label_type": "positive", "data_type": "clean"},
  {"text": "팀장이 성장 포인트를 중심으로 피드백을 구성해서 팀원이 도전 의욕을 잃지 않도록 했다.", "label_id": "M07-02", "label_name": "성장 지향 피드백", "label_type": "positive", "data_type": "clean"},
  {"text": "지금 부족한 부분을 채우면 팀에서 가장 중요한 역할을 맡을 수 있게 됩니다.", "label_id": "M07-02", "label_name": "성장 지향 피드백", "label_type": "positive", "data_type": "clean"},
  {"text": "이번에도 실망스러웠습니다. 지난번이랑 똑같은 실수를 반복했어요.", "label_id": "M07-02", "label_name": "성장 지향 피드백", "label_type": "positive", "data_type": "hard_negative", "is_negative_of": "M07-02"},
  {"text": "왜 항상 이 부분에서 문제가 생깁니까? 언제까지 이럴 건가요?", "label_id": "M07-02", "label_name": "성장 지향 피드백", "label_type": "positive", "data_type": "hard_negative", "is_negative_of": "M07-02"},
  {"text": "팀장이 과거의 실수를 반복해서 언급하며 팀원을 질책했다.", "label_id": "M07-02", "label_name": "성장 지향 피드백", "label_type": "positive", "data_type": "hard_negative", "is_negative_of": "M07-02"},
  {"text": "이번 결과가 나쁘면 다음 기회는 없을 수도 있습니다.", "label_id": "M07-02", "label_name": "성장 지향 피드백", "label_type": "positive", "data_type": "hard_negative", "is_negative_of": "M07-02"},
  {"text": "개선 방향 없이 이 부분이 문제라는 지적만 반복했다.", "label_id": "M07-02", "label_name": "성장 지향 피드백", "label_type": "positive", "data_type": "hard_negative", "is_negative_of": "M07-02"}
