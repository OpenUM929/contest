      "toxic_leader_high_threshold": 4,
      "toxic_leader_base_score": 0.3,
      "toxic_leader_increment": 0.15,
      "toxic_leader_max_score": 0.9,
      "negative_dominance_threshold": 0.2,
      "negative_dominance_high_threshold": 0.5,
      "integrity_risk_score": 0.7,
      "transparency_risk_score": 0.8,
      "psychological_safety_risk_score": 0.85
    }
  }
}
